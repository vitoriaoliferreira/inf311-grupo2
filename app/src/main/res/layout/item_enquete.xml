<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Vínculo com a palestra (oculto para enquetes gerais) -->
        <TextView
            android:id="@+id/tvEnquetePalestra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_poll"
            android:drawablePadding="6dp"
            android:drawableTint="#689F38"
            android:gravity="center_vertical"
            android:textColor="#689F38"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="Palestra: Vínculos que Protegem"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvEnquetePergunta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Qual tema você mais deseja se aprofundar?" />

        <!-- Opções (injetadas programaticamente pelo EnqueteAdapter) -->
        <LinearLayout
            android:id="@+id/llOpcoesEnquete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvEnqueteInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#888888"
            android:textSize="12sp"
            tools:text="Encerra em 2h 15m" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
