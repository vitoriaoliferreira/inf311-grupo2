<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Coluna Esquerda: Tempo (Hora e Data) -->
        <LinearLayout
            android:id="@+id/ll_time_section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minWidth="60dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_hora_proxima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#689F38"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="16:00" />

            <TextView
                android:id="@+id/tv_data_proxima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="14sp"
                tools:text="18/05" />
        </LinearLayout>

        <!-- Linha Divisória Vertical -->
        <View
            android:id="@+id/v_divider_proxima"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_marginStart="12dp"
            android:background="#E0E0E0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/ll_time_section"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Coluna Central: Título e Detalhes -->
        <LinearLayout
            android:id="@+id/ll_content_section"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_bookmark_proxima"
            app:layout_constraintStart_toEndOf="@id/v_divider_proxima"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_titulo_proxima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Vigilância socioassistencial no SUAS" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Local -->
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:contentDescription="Local"
                    android:src="@drawable/ic_location_on"
                    app:tint="#888888" />

                <TextView
                    android:id="@+id/tv_local_proxima"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    tools:text="Auditório do CCE" />

                <!-- Palestrante -->
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Palestrante"
                    android:src="@drawable/ic_person"
                    app:tint="#15438B" />

                <TextView
                    android:id="@+id/tv_palestrante_proxima"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="#15438B"
                    android:textSize="10sp"
                    tools:text="João Pereira" />

            </LinearLayout>
        </LinearLayout>

        <!-- Coluna Direita: Ícone de Marcador -->
        <ImageView
            android:id="@+id/iv_bookmark_proxima"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Favoritar"
            android:src="@drawable/ic_bookmark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#689F38" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
