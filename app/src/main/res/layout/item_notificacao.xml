<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_notif_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Avatar do Ícone (Esquerda) -->
        <FrameLayout
            android:id="@+id/fl_notif_icon_container"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_notif_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Ícone de Notificação"
                android:src="@drawable/ic_info"
                app:tint="@color/white" />

        </FrameLayout>

        <!-- Título -->
        <TextView
            android:id="@+id/tv_notif_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tv_notif_time"
            app:layout_constraintStart_toEndOf="@id/fl_notif_icon_container"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Mudança de Horário" />

        <!-- Corpo -->
        <TextView
            android:id="@+id/tv_notif_body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#616161"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/tv_notif_title"
            app:layout_constraintStart_toStartOf="@id/tv_notif_title"
            app:layout_constraintTop_toBottomOf="@id/tv_notif_title"
            tools:text="A palestra das 15h teve seu horário alterado para às 15:30h" />

        <!-- Horário -->
        <TextView
            android:id="@+id/tv_notif_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="10:30" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Divisória -->
    <View
        android:id="@+id/v_notif_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_notif_content" />

</androidx.constraintlayout.widget.ConstraintLayout>
