<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_blue"
    android:padding="24dp">

    <!-- Logo SUAS 360 -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_logo"
        app:layout_constraintBottom_toTopOf="@id/tvBemVindo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <!-- Bem-vindo ao SUAS 360 -->
    <TextView
        android:id="@+id/tvBemVindo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bem-vindo ao SUAS 360"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitulo" />

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestão, Impacto e Cidadania"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:alpha="0.85"
        app:layout_constraintTop_toBottomOf="@id/tvBemVindo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvLabelEmail"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="32dp" />

    <!-- Label Email -->
    <TextView
        android:id="@+id/tvLabelEmail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Email"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/layoutEmail" />

    <!-- Campo Email com ícone -->
    <LinearLayout
        android:id="@+id/layoutEmail"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvLabelEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvLabelSenha"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_email"
            android:alpha="0.5"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="email@email.com"
            android:inputType="textEmailAddress"
            android:background="@null"
            android:textSize="14sp"
            android:textColor="@color/text_dark"
            android:textColorHint="#AAAAAA" />
    </LinearLayout>

    <!-- Label Senha -->
    <TextView
        android:id="@+id/tvLabelSenha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Senha"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/layoutEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/layoutSenha" />

    <!-- Campo Senha com ícone -->
    <LinearLayout
        android:id="@+id/layoutSenha"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvLabelSenha"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvEsqueciSenha"
        android:layout_marginBottom="4dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_lock"
            android:alpha="0.5"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/etSenha"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="senha"
            android:inputType="textPassword"
            android:background="@null"
            android:textSize="14sp"
            android:textColor="@color/text_dark"
            android:textColorHint="#AAAAAA" />
    </LinearLayout>

    <!-- Esqueci minha senha -->
    <TextView
        android:id="@+id/tvEsqueciSenha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Esqueci minha senha"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:alpha="0.85"
        app:layout_constraintTop_toBottomOf="@id/layoutSenha"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvErro"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp" />

    <!-- Mensagem de erro -->
    <TextView
        android:id="@+id/tvErro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FF6B6B"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvEsqueciSenha"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnEntrar"
        android:layout_marginBottom="12dp" />

    <!-- Botão Entrar -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnEntrar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="Entrar"
        android:textColor="@color/white"
        android:background="@drawable/bg_button_green"
        android:backgroundTint="@null"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvErro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/progressLogin"
        android:layout_marginBottom="12dp" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/white"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnEntrar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvNaoRecebeu" />

    <!-- Não recebeu seu acesso? -->
    <TextView
        android:id="@+id/tvNaoRecebeu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Não recebeu seu acesso?"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:alpha="0.85"
        app:layout_constraintBottom_toTopOf="@id/tvRecuperarSenha"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="2dp" />

    <!-- Recuperar Senha -->
    <TextView
        android:id="@+id/tvRecuperarSenha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recuperar Senha"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/ivGesuas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp" />

    <!-- Logo GESUAS rodapé — só a imagem, sem texto -->
    <ImageView
        android:id="@+id/ivGesuas"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_gesuas"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:alpha="0.9"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>