<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Cabeçalho Global Fixo -->
    <include
        android:id="@+id/cabecalhoGlobal"
        layout="@layout/layout_cabecalho" />

    <!-- Rodapé: status + botão de confirmação -->
    <LinearLayout
        android:id="@+id/ll_rodape"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_status_presenca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:textColor="#888888"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="Disponível apenas durante o horário da palestra"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmarPresenca"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#689F38"
            android:text="Confirmar Presença"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_camera"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF" />

    </LinearLayout>

    <!-- Contentor Dinâmico (ScrollView) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/ll_rodape"
        app:layout_constraintTop_toBottomOf="@id/cabecalhoGlobal">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Título da Palestra -->
            <TextView
                android:id="@+id/tvDetalheTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="#15438B"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Vínculos que Protegem" />

            <!-- Tags de Informação (Horário e Sala) -->
            <LinearLayout
                android:id="@+id/llDetalheTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvDetalheTitulo">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_schedule"
                    app:tint="#689F38" />

                <TextView
                    android:id="@+id/tvDetalheHorario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="#689F38"
                    android:textStyle="bold"
                    tools:text="14:00" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_location_on"
                    app:tint="#888888" />

                <TextView
                    android:id="@+id/tvDetalheSala"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="#888888"
                    tools:text="Sala A" />
            </LinearLayout>

            <View
                android:id="@+id/vDetalheDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/llDetalheTags" />

            <!-- Secção Sobre -->
            <TextView
                android:id="@+id/tvLabelSobre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Sobre a palestra"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/vDetalheDivider" />

            <TextView
                android:id="@+id/tvDetalheDescricao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#666666"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/tvLabelSobre"
                tools:text="Conexões humanas que sustentam a proteção social no SUAS." />

            <!-- Secção Palestrante -->
            <TextView
                android:id="@+id/tvLabelPalestrante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Palestrante"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDetalheDescricao" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvDetalhePalestrante"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/tvLabelPalestrante">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/ivDetalheAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_avatar_placeholder"
                        android:contentDescription="Avatar"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvDetalheNomePalestrante"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@+id/tvDetalheCargoPalestrante"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivDetalheAvatar"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed"
                        tools:text="Mariana Torres" />

                    <TextView
                        android:id="@+id/tvDetalheCargoPalestrante"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@+id/tvDetalheNomePalestrante"
                        app:layout_constraintStart_toStartOf="@+id/tvDetalheNomePalestrante"
                        app:layout_constraintTop_toBottomOf="@+id/tvDetalheNomePalestrante"
                        tools:text="Assistente Social e Mestre" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
